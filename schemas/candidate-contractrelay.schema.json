{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ContractRelay route candidate",
  "type": "object",
  "required": [
    "name",
    "decision",
    "fail_closed",
    "errors",
    "reasons",
    "relay_token",
    "source",
    "target",
    "contract_id"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": ["RELAYED", "BLOCKED", "INVALID"]
    },
    "fail_closed": {
      "type": "boolean"
    },
    "errors": {
      "type": "array"
    },
    "reasons": {
      "type": "array"
    },
    "relay_token": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "target": {
      "type": "string"
    },
    "contract_id": {
      "type": "string"
    },
    "route_id": {
      "type": "string"
    },
    "verified": {
      "type": "boolean"
    },
    "confidence": {
      "type": "number",
      "minimum": 0
    }
  }
}
