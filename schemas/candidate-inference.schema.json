{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "InferMesh candidate",
  "type": "object",
  "required": [
    "name",
    "available_tflops",
    "renewable_pct",
    "marginal_grid_cost"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "available_tflops": {
      "type": "number",
      "minimum": 0
    },
    "renewable_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "marginal_grid_cost": {
      "type": "number",
      "minimum": 0
    }
  }
}
