{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WattWeave candidate",
  "type": "object",
  "required": [
    "name",
    "perf",
    "cost",
    "carbon"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "perf": {
      "type": "number",
      "minimum": 0
    },
    "cost": {
      "type": "number",
      "minimum": 0
    },
    "carbon": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "latency_ms": {
      "type": "number",
      "minimum": 0
    },
    "sovereignty_ok": {
      "type": "boolean"
    },
    "chip_available": {
      "type": "boolean"
    }
  }
}
