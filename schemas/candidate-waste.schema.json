{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WasteStack telemetry",
  "type": "object",
  "required": [
    "tenant_draw_mw",
    "interconnect_mw",
    "heat_output_mw",
    "offtake_capacity_mw"
  ],
  "properties": {
    "tenant_draw_mw": {
      "type": "number",
      "minimum": 0
    },
    "interconnect_mw": {
      "type": "number",
      "minimum": 0
    },
    "heat_output_mw": {
      "type": "number",
      "minimum": 0
    },
    "offtake_capacity_mw": {
      "type": "number",
      "minimum": 0
    }
  }
}
