{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Route plan (route() result)",
  "type": "object",
  "required": [
    "all_scores"
  ],
  "properties": {
    "selected": {
      "type": [
        "string",
        "null"
      ]
    },
    "selected_score": {
      "type": "number"
    },
    "selected_evidence": {
      "type": [
        "string",
        "null"
      ]
    },
    "all_scores": {
      "type": "array",
      "items": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "ScoreResult",
        "type": "object",
        "required": [
          "name",
          "score",
          "eligible"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "score": {
            "type": "number"
          },
          "eligible": {
            "type": "boolean"
          },
          "verified": {
            "type": "boolean"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "demand": {
      "type": "object"
    },
    "routed_at": {
      "type": "string"
    }
  }
}
